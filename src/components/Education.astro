---
const education = [
  {
    school: 'Yale School of Management',
    logo: '/portfolio/images/logos/yale.png',
    degree: 'Master of Business Administration (MBA)',
    honors: "Dean's Scholar",
    date: '2022 – 2024',
    location: 'New Haven, CT',
    bullets: [
      'Concentration in Strategy and Operations',
      "Dean's Scholar recognition for academic excellence",
    ],
  },
  {
    school: 'Indian Institute of Technology Madras',
    logo: '/portfolio/images/logos/iitm.png',
    degree: 'Bachelor of Technology, Chemical Engineering',
    honors: 'Top 10%',
    date: '2011 – 2015',
    location: 'Chennai, India',
    bullets: [
      'Graduated in top 10% of class',
      'Foundations in process engineering, thermodynamics, and applied mathematics',
    ],
  },
];
---

<section id="education" class="py-20 lg:py-28 bg-surface">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 xl:px-16">
    <div class="section-divider mb-16"></div>

    <p class="reveal font-mono text-accent text-sm tracking-widest uppercase mb-2">EDUCATION</p>
    <h2 class="reveal font-display text-3xl lg:text-4xl font-bold text-ink mb-12">
      Where I <span class="text-gradient">Studied</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {education.map((edu) => (
        <div class="reveal glass-card spotlight-card rounded-xl p-6">
          <div class="flex items-start gap-4">
            <img src={edu.logo} alt={edu.school} class="w-12 h-12 object-contain shrink-0 mt-1" loading="lazy" />
            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-display text-lg font-semibold text-ink">{edu.school}</h3>
                  <p class="text-muted font-medium text-sm">{edu.degree}</p>
                </div>
                <span class="font-mono text-sm text-accent/70 whitespace-nowrap shrink-0">{edu.date}</span>
              </div>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-xs font-mono px-2.5 py-1 bg-accent-light text-accent rounded-md border border-accent/10">{edu.honors}</span>
                <span class="text-xs text-muted">{edu.location}</span>
              </div>
            </div>
          </div>
          <ul class="mt-4 space-y-2">
            {edu.bullets.map((bullet) => (
              <li class="text-muted text-sm leading-relaxed flex items-start gap-2">
                <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-accent/60"></span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  let eduSpotlightInit = false;
  const initEduSpotlight = () => {
    if (eduSpotlightInit) return;
    const cards = document.querySelectorAll('#education .spotlight-card');
    if (!cards.length) return;
    eduSpotlightInit = true;

    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const el = card as HTMLElement;
        const rect = el.getBoundingClientRect();
        el.style.setProperty('--mouse-x', `${(e as MouseEvent).clientX - rect.left}px`);
        el.style.setProperty('--mouse-y', `${(e as MouseEvent).clientY - rect.top}px`);
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEduSpotlight);
  } else {
    initEduSpotlight();
  }
  document.addEventListener('astro:page-load', initEduSpotlight);
</script>
