<section id="contact" class="py-20 lg:py-28 bg-surface">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 xl:px-16">
    <div class="section-divider mb-16"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left: heading + info -->
      <div class="reveal">
        <p class="font-mono text-accent text-sm tracking-widest uppercase mb-2">CONTACT</p>
        <h2 class="font-display text-3xl lg:text-4xl font-bold text-ink mb-4">
          Let's Work <span class="text-gradient-shimmer">Together</span>
        </h2>
        <p class="text-muted text-lg leading-relaxed mb-8 max-w-md">
          Have a project in mind or want to chat? Fill out the form and I'll get back to you shortly.
        </p>

        <div class="space-y-4">
          <a href="mailto:basithnijamudeen@gmail.com" class="flex items-center gap-3 text-muted hover:text-accent transition-colors group">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-accent-light text-accent group-hover:bg-accent group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </span>
            <span class="font-medium">basithnijamudeen@gmail.com</span>
          </a>

          <div class="flex items-center gap-3 text-muted">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-accent-light text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <span class="font-medium">Houston, TX</span>
          </div>

          <div class="flex gap-3 pt-2">
            <a href="https://github.com/basithzohailn" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full border border-border text-muted hover:bg-accent hover:text-white hover:border-accent transition-all" aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
              </svg>
            </a>
            <a href="https://www.linkedin.com/in/basithnijamudeen/" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full border border-border text-muted hover:bg-accent hover:text-white hover:border-accent transition-all" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal">
        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="glass-card rounded-2xl p-6 sm:p-8 space-y-5">
          <input type="hidden" name="access_key" value="d75a4d05-5387-4a2e-b29b-c50d43721233" />
          <input type="hidden" name="subject" value="New message from portfolio" />
          <input type="hidden" name="from_name" value="Portfolio Contact Form" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-ink mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                class="w-full px-4 py-3 rounded-xl border border-border bg-canvas text-ink placeholder:text-muted/50 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all text-sm"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@example.com"
                class="w-full px-4 py-3 rounded-xl border border-border bg-canvas text-ink placeholder:text-muted/50 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all text-sm"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell me about your project or question..."
              class="w-full px-4 py-3 rounded-xl border border-border bg-canvas text-ink placeholder:text-muted/50 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all text-sm resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full inline-flex items-center justify-center gap-2 bg-ink text-white px-8 py-3.5 rounded-full font-medium shadow-xl shadow-ink/15 hover:shadow-ink/25 hover:bg-ink/90 transition-all press-scale"
          >
            <span id="btn-text">Send Message</span>
            <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>

          <p id="form-success" class="hidden text-center text-sm text-green-600 font-medium mt-2">
            Message sent! I'll get back to you soon.
          </p>
          <p id="form-error" class="hidden text-center text-sm text-red-500 font-medium mt-2">
            Something went wrong. Please try again or email me directly.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  let contactInit = false;
  const initContactForm = () => {
    if (contactInit) return;
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;
    contactInit = true;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('btn-text');
      const btnIcon = document.getElementById('btn-icon');
      const success = document.getElementById('form-success');
      const error = document.getElementById('form-error');

      if (btn) btn.disabled = true;
      if (btnText) btnText.textContent = 'Sending...';
      if (btnIcon) btnIcon.style.display = 'none';
      success?.classList.add('hidden');
      error?.classList.add('hidden');

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await res.json();

        if (data.success) {
          form.reset();
          success?.classList.remove('hidden');
          setTimeout(() => success?.classList.add('hidden'), 6000);
        } else {
          error?.classList.remove('hidden');
        }
      } catch {
        error?.classList.remove('hidden');
      } finally {
        if (btn) btn.disabled = false;
        if (btnText) btnText.textContent = 'Send Message';
        if (btnIcon) btnIcon.style.display = '';
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
  document.addEventListener('astro:page-load', initContactForm);
</script>
