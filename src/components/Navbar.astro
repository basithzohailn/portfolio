---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Education', href: '#education' },
  { label: 'Tech', href: '#tech-stack' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---

<header
  id="main-nav"
  class="fixed top-0 w-full z-50 transition-all duration-300 bg-white/60 backdrop-blur-xl backdrop-saturate-150 border-b border-white/20"
  style="--webkit-backdrop-filter: blur(20px) saturate(180%);"
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 xl:px-16 flex justify-between items-center py-5">
    <!-- Logo -->
    <a href="#hero" class="font-display font-bold text-xl text-ink hover:text-accent transition-colors">BN<span class="text-accent">.</span></a>

    <!-- Desktop nav with pill indicator -->
    <nav class="hidden md:flex items-center relative" aria-label="Main navigation">
      <div id="nav-pill" class="absolute h-8 rounded-full bg-accent/10 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] opacity-0" style="top: 50%; transform: translateY(-50%);"></div>
      <div class="flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            class="relative z-10 text-muted hover:text-accent transition-colors font-medium text-sm px-4 py-1.5 rounded-full"
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line block w-6 h-0.5 bg-ink transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-ink transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-ink transition-all duration-300 origin-center"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden bg-white/70 backdrop-blur-xl backdrop-saturate-150 border-b border-white/20"
    aria-label="Mobile navigation"
  >
    <div class="max-w-[1400px] mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-nav-link
          class="text-muted hover:text-accent transition-colors font-medium text-sm py-1"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  let navInit = false;
  const initNavbar = () => {
    if (navInit) return;
    const header = document.getElementById('main-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const navLinks = document.querySelectorAll('[data-nav-link]');
    const lines = menuBtn?.querySelectorAll('.hamburger-line');
    const pill = document.getElementById('nav-pill');

    if (!header || !menuBtn || !mobileMenu) return;
    navInit = true;

    let isOpen = false;

    const updateHeaderBg = () => {
      if (window.scrollY > 80) {
        header.classList.add('bg-white/70', 'shadow-[0_1px_3px_rgba(0,0,0,0.05)]');
        header.classList.remove('bg-white/60');
      } else {
        header.classList.remove('bg-white/70', 'shadow-[0_1px_3px_rgba(0,0,0,0.05)]');
        header.classList.add('bg-white/60');
      }
    };

    window.addEventListener('scroll', updateHeaderBg, { passive: true });
    updateHeaderBg();

    const toggleMenu = () => {
      isOpen = !isOpen;
      mobileMenu.classList.toggle('hidden', !isOpen);
      menuBtn.setAttribute('aria-expanded', String(isOpen));

      if (lines && lines.length === 3) {
        if (isOpen) {
          lines[0].style.transform = 'translateY(8px) rotate(45deg)';
          lines[1].style.opacity = '0';
          lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
        } else {
          lines[0].style.transform = '';
          lines[1].style.opacity = '';
          lines[2].style.transform = '';
        }
      }
    };

    menuBtn.addEventListener('click', toggleMenu);

    mobileMenu.querySelectorAll('[data-nav-link]').forEach((link) => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });

    // Active section highlighting + pill indicator
    const sections = ['hero', 'about', 'experience', 'education', 'tech-stack', 'projects', 'contact'];
    const sectionElements = sections
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    const desktopLinks = header.querySelectorAll('nav:not(#mobile-menu) [data-nav-link]') as NodeListOf<HTMLElement>;

    const movePill = (activeLink: HTMLElement | null) => {
      if (!pill || !activeLink) {
        if (pill) pill.style.opacity = '0';
        return;
      }
      const nav = activeLink.closest('nav');
      if (!nav) return;

      pill.style.opacity = '1';
      pill.style.left = `${activeLink.offsetLeft}px`;
      pill.style.width = `${activeLink.offsetWidth}px`;
    };

    const highlightActive = () => {
      const scrollY = window.scrollY + 120;

      let current = '';
      for (const section of sectionElements) {
        if (section.offsetTop <= scrollY) {
          current = section.id;
        }
      }

      let activeDesktopLink: HTMLElement | null = null;

      navLinks.forEach((link) => {
        const href = link.getAttribute('href');
        if (href === `#${current}`) {
          link.classList.remove('text-muted');
          link.classList.add('text-accent');
          if ((link as HTMLElement).closest('nav:not(#mobile-menu)')) {
            activeDesktopLink = link as HTMLElement;
          }
        } else {
          link.classList.remove('text-accent');
          link.classList.add('text-muted');
        }
      });

      movePill(activeDesktopLink);
    };

    window.addEventListener('scroll', highlightActive, { passive: true });
    window.addEventListener('resize', highlightActive, { passive: true });
    highlightActive();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNavbar);
  } else {
    requestAnimationFrame(initNavbar);
  }
  document.addEventListener('astro:page-load', initNavbar);
</script>
