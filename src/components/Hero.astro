---
import AnimatedHeadshot from './AnimatedHeadshot';
const roles = ["Management Consultant", "AI Product Builder", "Full Stack Engineer", "Chemical Engineer", "Oil & Gas Strategist"];
---

<section id="hero" class="min-h-dvh flex items-center pt-28 lg:pt-20 relative overflow-hidden">
  <!-- Mobile orb (visible on small screens) -->
  <div
    class="hero-orb-mobile absolute top-20 right-0 translate-x-1/3 lg:hidden"
    aria-hidden="true"
  ></div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 xl:px-16 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-center">
      <!-- Mobile headshot (above text on small screens) -->
      <div class="flex lg:hidden justify-center items-center relative">
        <AnimatedHeadshot client:load />
      </div>

      <!-- Left column: text (60%) -->
      <div class="lg:col-span-3 text-center lg:text-left">
        <p class="font-mono text-accent text-sm tracking-widest uppercase reveal">
          Hello, I'm
        </p>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-7xl font-bold leading-[1.1] mt-3 reveal text-gradient-shimmer">
          Basith<br />Nijamudeen
        </h1>

        <div class="mt-5 reveal">
          <p class="font-display text-accent text-xl sm:text-2xl lg:text-3xl font-semibold h-8 sm:h-10 lg:h-12">
            <span id="typewriter-text">Management Consultant</span><span class="typewriter-cursor" aria-hidden="true"></span>
            <span class="sr-only">{roles.join(', ')}</span>
          </p>
          <div class="w-16 h-1 bg-gradient-to-r from-accent to-accent-sky rounded-full mt-3 mx-auto lg:mx-0"></div>
        </div>

        <p class="text-muted text-base sm:text-lg leading-relaxed max-w-lg mt-6 reveal mx-auto lg:mx-0">
          I build production AI tools that turn complex business problems into
          elegant software solutions.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-center gap-3 sm:gap-4 reveal justify-center lg:justify-start">
          <a
            href="#projects"
            class="group inline-flex items-center justify-center gap-3 bg-ink text-white w-full sm:w-auto px-8 py-3.5 rounded-full font-medium shadow-xl shadow-ink/15 hover:shadow-ink/25 hover:bg-ink/90 transition-all press-scale"
          >
            View Projects
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-white/15 group-hover:bg-white/25 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </span>
          </a>
          <a
            href="#contact"
            class="group inline-flex items-center justify-center gap-3 bg-surface text-ink w-full sm:w-auto px-8 py-3.5 rounded-full font-medium border border-border hover:border-accent/30 hover:shadow-lg hover:shadow-accent/10 transition-all press-scale"
          >
            Get in Touch
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent transition-transform group-hover:translate-x-0.5">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <!-- Desktop headshot -->
      <div class="hidden lg:flex lg:col-span-2 justify-center items-center relative">
        <div
          class="hero-orb absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
          aria-hidden="true"
        ></div>
        <AnimatedHeadshot client:load />
      </div>
    </div>
  </div>

  <!-- Floating geometric dots (desktop only) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none hidden lg:block" aria-hidden="true">
    <div class="absolute top-1/4 left-[10%] w-2 h-2 rounded-full bg-accent/20 animate-pulse"></div>
    <div class="absolute top-1/3 right-[15%] w-1.5 h-1.5 rounded-full bg-accent-sky/20 animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-1/4 left-[20%] w-1 h-1 rounded-full bg-accent/15 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute top-2/3 right-[25%] w-2.5 h-2.5 rounded-full bg-accent/10 animate-pulse" style="animation-delay: 0.5s;"></div>
    <div class="absolute bottom-1/3 left-[40%] w-1.5 h-1.5 rounded-full bg-accent-sky/15 animate-pulse" style="animation-delay: 1.5s;"></div>
  </div>
</section>

<script is:inline>
  (function() {
    var phrases = ['Management Consultant', 'AI Product Builder', 'Full Stack Engineer', 'Chemical Engineer', 'Oil & Gas Strategist'];

    function startTypewriter() {
      if (window.__twRunning) return;
      var el = document.getElementById('typewriter-text');
      if (!el) return;
      window.__twRunning = true;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.textContent = phrases[0];
        return;
      }

      var pi = 0, ci = phrases[0].length, del = true;

      function tick() {
        var current = phrases[pi];
        if (del) { ci--; } else { ci++; }
        el.textContent = current.substring(0, ci);

        var d = del ? 35 : 70;

        if (!del && ci === current.length) {
          d = 2200; del = true;
        } else if (del && ci === 0) {
          del = false;
          pi = (pi + 1) % phrases.length;
          d = 400;
        }

        setTimeout(tick, d);
      }

      setTimeout(tick, 2200);
    }

    // Try every strategy to ensure this runs
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      startTypewriter();
    }
    document.addEventListener('DOMContentLoaded', startTypewriter);
    window.addEventListener('load', startTypewriter);
    setTimeout(startTypewriter, 100);
    setTimeout(startTypewriter, 500);
    setTimeout(startTypewriter, 2000);
  })();
</script>
