---
import ProjectGrid from './ProjectGrid';
---

<section id="projects" class="py-20 lg:py-28">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 xl:px-16">
    <div class="section-divider mb-16"></div>

    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-2 reveal">PROJECTS</p>
    <h2 class="font-display text-3xl lg:text-4xl font-bold mb-12 reveal text-ink">Featured <span class="text-gradient">Projects</span></h2>

    <ProjectGrid client:load />
  </div>
</section>
